# API
PORT=3000
NODE_ENV=development

# Neon Postgres (https://neon.tech, free tier)
# Get a connection string from your project's Connection Details.
DATABASE_URL=postgresql://user:pass@ep-xxx.neon.tech/neondb?sslmode=require

# 0xwork public API
ZEROXWORK_API_URL=https://api.0xwork.org
IPFS_GATEWAY=https://ipfs.io/ipfs/

# Groq (free tier — get a key at https://console.groq.com)
# Leave blank to run in heuristics-only mode (no LLM verdict).
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# x402 — Base mainnet wallet that receives payments
# Set X402_BYPASS=true during local dev to skip payment verification.
X402_PAY_TO=0x0000000000000000000000000000000000000000
X402_NETWORK=base
X402_FACILITATOR_URL=https://x402.org/facilitator
X402_BYPASS=true

# Pricing in USDC, per tier
PRICE_FAST_USDC=0.05
PRICE_FULL_USDC=0.50

# Telegram bot (https://t.me/BotFather)
TELEGRAM_BOT_TOKEN=
# Public URL of your Mini App (Cloudflare Pages, Render static, etc.)
MINIAPP_URL=https://your-miniapp.example.com
# Public URL of this API (Render service URL)
API_BASE_URL=http://localhost:3000
# Port and public URL of the bot's HTTP server (used by the Mini App to fetch session data)
BOT_PORT=3001
BOT_PUBLIC_URL=http://localhost:3001
